{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Git Reviewer",
  "version": "0.1.0",
  "identifier": "com.git-reviewer.app",
  "build": {
    "frontendDist": "../../server/public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Git Reviewer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Local git code review tool",
      "args": [
        {
          "name": "base",
          "short": "b",
          "description": "Base ref (branch, tag, or commit)",
          "takesValue": true
        },
        {
          "name": "head",
          "short": "H",
          "description": "Head ref (branch, tag, or commit)",
          "takesValue": true
        },
        {
          "name": "repo",
          "short": "r",
          "description": "Path to git repository",
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
